{
  "manifest_version": 2,
  "name": "CopyTitleFF",
  "version": "0.1",

  "description": "Firefox extension that allows to copy title and url with single shortcut. Useful for notetaking.",

  "background": {
    "scripts": ["background.js"]
  },

  "commands": {
    "copy-title-url": {
      "suggested_key": {
        "default": "Ctrl+Y"
      },
      "description": "Copy title and url"
    }
  },

  "permissions": [
    "activeTab",
    "clipboardWrite"
  ]
}
